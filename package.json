{
  "name": "dev-with-min",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview --host",
    "astro": "astro",
    "new:post": "bun scripts/new-post.mjs",
    "check:public": "bun run build && bun scripts/check-public-build.mjs",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.astro --fix",
    "check:astro": "astro check",
    "check": "bun run format:check && bun run lint && bun run check:astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "astro-expressive-code": "^0.44.0",
    "lucide-astro": "^0.556.0",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
