---
type CalloutVariant = "note" | "warning" | "decision" | "reference" | "tip" | "question" | "todo" | "danger";

interface Props {
  title?: string;
  variant?: CalloutVariant;
}

const labels: Record<CalloutVariant, string> = {
  note: "Note",
  warning: "Warning",
  decision: "Decision",
  reference: "Reference",
  tip: "Tip",
  question: "Question",
  todo: "Todo",
  danger: "Danger",
};

const { title, variant = "note" } = Astro.props;
const resolvedTitle = title ?? labels[variant];
---

<aside class={`callout callout--${variant}`}>
  <div class="callout__header">
    <span class="callout__marker" aria-hidden="true"></span>
    <strong>{resolvedTitle}</strong>
  </div>
  <div class="callout__body">
    <slot />
  </div>
</aside>
