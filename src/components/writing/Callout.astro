---
type CalloutVariant = "note" | "warning" | "decision" | "reference" | "tip" | "question" | "todo" | "danger";

interface Props {
  title?: string;
  variant?: CalloutVariant;
}

const labels: Record<CalloutVariant, string> = {
  note: "Note",
  warning: "Warning",
  decision: "Decision",
  reference: "Reference",
  tip: "Tip",
  question: "Question",
  todo: "Todo",
  danger: "Danger",
};

const icons: Record<CalloutVariant, string[]> = {
  note: ["M12 20h9", "M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"],
  warning: [
    "M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z",
    "M12 9v4",
    "M12 17h.01",
  ],
  decision: ["M20 6 9 17l-5-5", "M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"],
  reference: ["M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2Z", "M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7Z"],
  tip: ["M15 14c.2-1 .7-1.7 1.5-2.5A4.5 4.5 0 1 0 8 11.5c.8.8 1.3 1.5 1.5 2.5", "M9 18h6", "M10 22h4", "M10 14h4"],
  question: ["M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z", "M9.09 9a3 3 0 1 1 5.83 1c0 2-3 2.5-3 4", "M12 17h.01"],
  todo: ["M9 6h11", "M9 12h11", "M9 18h11", "M4 6l1 1 2-2", "M4 12l1 1 2-2", "M4 18l1 1 2-2"],
  danger: ["M7.86 2h8.28L22 7.86v8.28L16.14 22H7.86L2 16.14V7.86Z", "M12 8v4", "M12 16h.01"],
};

const { title, variant = "note" } = Astro.props;
const resolvedTitle = title ?? labels[variant];
const iconPaths = icons[variant];
---

<aside class={`callout callout--${variant}`}>
  <div class="callout__header">
    <span class="callout__marker" aria-hidden="true">
      <svg
        class="callout__icon"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        {iconPaths.map((path) => <path d={path}></path>)}
      </svg>
    </span>
    <strong>{resolvedTitle}</strong>
  </div>
  <div class="callout__body">
    <slot />
  </div>
</aside>
