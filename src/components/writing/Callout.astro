---
import {
  BookOpen,
  CircleCheck,
  CircleHelp,
  Lightbulb,
  ListChecks,
  NotebookPen,
  OctagonAlert,
  TriangleAlert,
} from "lucide-astro";

type CalloutVariant =
  "note" | "warning" | "decision" | "reference" | "tip" | "question" | "todo" | "danger";

interface Props {
  title?: string;
  variant?: CalloutVariant;
}

const labels: Record<CalloutVariant, string> = {
  note: "Note",
  warning: "Warning",
  decision: "Decision",
  reference: "Reference",
  tip: "Tip",
  question: "Question",
  todo: "Todo",
  danger: "Danger",
};

const icons = {
  note: NotebookPen,
  warning: TriangleAlert,
  decision: CircleCheck,
  reference: BookOpen,
  tip: Lightbulb,
  question: CircleHelp,
  todo: ListChecks,
  danger: OctagonAlert,
};

const { title, variant = "note" } = Astro.props;
const resolvedTitle = title ?? labels[variant];
const Icon = icons[variant];
---

<aside class={`callout callout--${variant}`}>
  <div class="callout__header">
    <span class="callout__marker" aria-hidden="true">
      <Icon class="callout__icon" aria-hidden="true" />
    </span>
    <strong>{resolvedTitle}</strong>
  </div>
  <div class="callout__body">
    <slot />
  </div>
</aside>
