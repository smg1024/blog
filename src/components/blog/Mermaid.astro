---
interface Props {
  title?: string;
  caption?: string;
  chart?: string;
}

const { title, caption, chart } = Astro.props;
const diagram = chart?.trim();
---

<figure class="mermaid-figure">
  {title && <div class="mermaid-figure__title">{title}</div>}
  <div class="mermaid-figure__canvas">
    <pre class="mermaid" data-mermaid-diagram>{diagram}<slot /></pre>
  </div>
  {caption && <figcaption class="mermaid-figure__caption">{caption}</figcaption>}
</figure>

<script>
  import mermaid from "mermaid";

  // Mermaid bakes colors into the rendered SVG, so we keep each diagram's source text
  // to re-render it (with fresh Catppuccin variables) whenever the theme toggles.
  const sources = new WeakMap<HTMLElement, string>();

  const readCssVar = (name: string, fallback: string) => {
    const value = getComputedStyle(document.documentElement).getPropertyValue(name).trim();

    return value || fallback;
  };

  const getMermaidThemeVariables = () => {
    const bg = readCssVar("--bg", "#eff1f5");
    const surface = readCssVar("--surface", "#e6e9ef");
    const surfaceAlt = readCssVar("--surface-alt", "#dce0e8");
    const ink = readCssVar("--ink", "#4c4f69");
    const muted = readCssVar("--muted", "#5c5f77");
    const line = readCssVar("--line", "#ccd0da");
    const lineStrong = readCssVar("--line-strong", "#bcc0cc");
    const accent = readCssVar("--accent", "#8839ef");

    return {
      background: surface,
      darkMode: document.documentElement.dataset.theme === "dark",
      fontFamily: getComputedStyle(document.documentElement).fontFamily,
      lineColor: accent,
      primaryBorderColor: lineStrong,
      primaryColor: surfaceAlt,
      primaryTextColor: ink,
      secondaryBorderColor: line,
      secondaryColor: surface,
      secondaryTextColor: ink,
      tertiaryBorderColor: line,
      tertiaryColor: surface,
      tertiaryTextColor: ink,
      textColor: ink,
      titleColor: ink,

      actorBkg: surfaceAlt,
      actorBorder: lineStrong,
      actorLineColor: lineStrong,
      actorTextColor: ink,
      arrowheadColor: accent,
      clusterBkg: bg,
      clusterBorder: line,
      defaultLinkColor: accent,
      edgeLabelBackground: surface,
      labelTextColor: ink,
      mainBkg: surfaceAlt,
      nodeBkg: surfaceAlt,
      nodeBorder: lineStrong,
      nodeTextColor: ink,
      signalColor: accent,
      signalTextColor: ink,

      attributeBackgroundColorEven: surfaceAlt,
      attributeBackgroundColorOdd: surface,
      erEdgeLabelBackground: surface,
      relationColor: accent,
      relationLabelBackground: surface,
      relationLabelColor: muted,
    };
  };

  const renderMermaid = async () => {
    const diagrams = document.querySelectorAll<HTMLElement>(
      "[data-mermaid-diagram]:not([data-processed='true'])",
    );

    if (diagrams.length === 0) {
      return;
    }

    // Remember each diagram's source before Mermaid replaces it with an SVG.
    diagrams.forEach((node) => {
      if (!sources.has(node)) sources.set(node, node.textContent ?? "");
    });

    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "strict",
      theme: "base",
      themeVariables: getMermaidThemeVariables(),
      flowchart: {
        htmlLabels: false,
        useMaxWidth: true,
      },
      sequence: {
        useMaxWidth: true,
      },
    });

    try {
      await mermaid.run({
        nodes: diagrams,
      });
    } catch (error) {
      diagrams.forEach((diagram) => {
        if (!diagram.querySelector("svg")) {
          diagram.dataset.mermaidError = "true";
        }
      });
      console.error("Mermaid render failed", error);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => void renderMermaid(), { once: true });
  } else {
    void renderMermaid();
  }

  document.addEventListener("astro:page-load", () => void renderMermaid());

  // The rendered SVG has baked-in colors, so re-render from source when the theme changes
  // to repaint diagrams with the active Catppuccin (Latte or Macchiato) variables.
  const rerenderForTheme = () => {
    document.querySelectorAll<HTMLElement>("[data-mermaid-diagram]").forEach((node) => {
      const source = sources.get(node);
      if (source == null) return;
      node.textContent = source;
      delete node.dataset.processed;
      delete node.dataset.mermaidError;
    });
    void renderMermaid();
  };

  new MutationObserver(rerenderForTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>
