---
import { GitPullRequest } from "lucide-astro";

interface Props {
  repo: string;
  number: number;
}

const { repo, number } = Astro.props;
---

<a
  class="github-pull-request"
  href={`https://github.com/${repo}/pull/${number}`}
  target="_blank"
  rel="noopener noreferrer"
>
  <GitPullRequest aria-hidden="true" />
  <span><slot>{`PR #${number}`}</slot></span>
</a>

<style>
  .github-pull-request {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.15em 0.6em;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.85em;
    text-decoration: none;
    vertical-align: middle;
  }

  .github-pull-request:hover {
    border-color: var(--accent-strong);
    color: var(--accent-strong);
  }

  .github-pull-request :global(svg) {
    width: 1em;
    height: 1em;
  }
</style>
