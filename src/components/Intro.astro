---
import { currentFocus } from '../data/site';
---

<section class="intro-strip" aria-labelledby="focus-title">
	<div>
		<p class="eyebrow">Current focus</p>
		<h2 id="focus-title">A working record of learning, building, and revising.</h2>
	</div>
	<ul class="focus-list" aria-label="Current focus areas">
		{currentFocus.map((item) => <li>{item}</li>)}
	</ul>
</section>
