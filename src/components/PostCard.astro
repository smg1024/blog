---
import type { BlogEntry } from "../lib/content";
import { formatDate, getBlogUrl } from "../lib/content";

interface Props {
  post: BlogEntry;
}

const { post } = Astro.props;
const isDraftPost = import.meta.env.DEV && post.data.draft;
---

<a class:list={["post-card", { "post-card--draft": isDraftPost }]} href={getBlogUrl(post)}>
  <article class="post-card__inner">
    <div class="post-meta">
      <span>{formatDate(post.data.publishedAt)}</span>
      {isDraftPost && <span class="draft-badge">Draft</span>}
    </div>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    {
      post.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {post.data.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
  </article>
</a>
