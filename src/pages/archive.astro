---
import Layout from "../layouts/Layout.astro";
import { formatDate, getPublishedBlog, getSectionLabel, getBlogUrl } from "../lib/content";

const posts = await getPublishedBlog();
---

<Layout title="Archive" description="Complete blog archive, newest first.">
  <header class="page-header">
    <p class="eyebrow">Blog index</p>
    <h1>Archive</h1>
    <p>Newest first, sectioned, tagged, durable.</p>
  </header>

  <section class="page-section" aria-labelledby="archive-list-title">
    <div class="section-heading">
      <div>
        <h2 id="archive-list-title">All posts</h2>
      </div>
    </div>
    {
      posts.length > 0 ? (
        <ul class="archive-list">
          {posts.map((post) => (
            <li>
              <a href={getBlogUrl(post)}>
                <span>{formatDate(post.data.publishedAt)}</span>
                <strong>{post.data.title}</strong>
                <span>{getSectionLabel(post.data.section)}</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">No posts yet.</p>
      )
    }
  </section>
</Layout>
