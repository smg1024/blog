---
import { projectSeeds } from '../data/site';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects" description="Portfolio and project records from Dev with Min.">
	<header class="page-header">
		<p class="eyebrow">Portfolio</p>
		<h1>Projects</h1>
		<p>
			Portfolio-style records of the systems, tools, experiments, and learning projects that shape
			my developer experience.
		</p>
	</header>

	<section class="page-section" aria-labelledby="projects-list-title">
		<div class="section-heading">
			<div>
				<h2 id="projects-list-title">Project seeds</h2>
				<p>These placeholders define the first project lanes before detailed case studies are written.</p>
			</div>
		</div>
		<div class="card-grid">
			{projectSeeds.map((project) => (
				<article class="project-card">
					<div class="card-meta">{project.status}</div>
					<h2>{project.title}</h2>
					<p>{project.description}</p>
					<ul class="tag-list" aria-label={`${project.title} tags`}>
						{project.tags.map((tag) => <li>{tag}</li>)}
					</ul>
				</article>
			))}
		</div>
	</section>
</Layout>
