const skills = [
  { category: "Cloud / Infra / Ops", items: ["Linux", "NixOS", "GitHub Actions", "Docker"] },
  { category: "Backend", items: ["Java", "Spring Boot"] },
  { category: "Database", items: ["PostgreSQL", "Oracle"] },
  { category: "Frontend", items: ["TypeScript", "React"] },
