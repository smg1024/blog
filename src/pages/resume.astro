    tagline: "폐쇄형 그룹 내 토픽 기반 썰 풀기 웹앱",
    github: "https://github.com/jamye-plz/jamye-plz",
    points: [
      "FastAPI backend와 SvelteKit PWA frontend를 Nix Flake로 패키징",
      "NixOS module을 작성해 PostgreSQL, Alembic migration, Uvicorn backend, Caddy reverse proxy를 systemd 서비스로 선언적 배포",
      "Homelab의 aarch cloud node에 배포하고, public ingress는 별도 edge node의 Cloudflare Tunnel/Caddy 구조에 위임",
    ],
  },
  {
    name: "SPETTRUM",
    period: "2023.06 - 2024.12",
    stack: [
      "Spring Boot",
      "Java 17",
      "Python",
      "Runpod Serverless API",
      "Docker",
      "Nginx",
      "GitHub Actions",
    ],
    tagline:
      "나의 반려동물의 모습으로 프롬프트 기반 AI 이미지를 생성하는 반려동물 AI 온라인 스튜디오 어플",
    points: [
      "Stable Diffusion 기반 반려동물 AI 이미지 생성 파이프라인 구축",
      "비동기 이미지 생성 요청 처리 구조 설계 및 Spring Boot 백엔드 연동",
      "GPU Serverless API의 Dockerize로 온프레미스 GPU 서버 운영 대비 비용 절감",
      "GitHub Actions, Docker Compose, Nginx 기반 CI/CD 및 무중단 Blue/Green 배포 구성",
    ],
  },
];

interface Activity {
  period: string;
  title: string;
  detail: string;
  link?: { label: string; href: string };
}

const activities: Activity[] = [
  {
    period: "2024.06 - 2025.01",
    title: "CES 2025 Eureka Park 참여",
    detail: "컴퓨터 비전 기반의 개별 반려동물 디지털화 파인튜닝 모델 및 코딩 시스템, Pawframe",
    link: { label: "기술 소개 페이지", href: "https://unpeil.github.io/" },
  },
  {
    period: "2024.03 - 2024.11",
    title: "학생창업유망 300+ 성장트랙 장려상",
    detail: "AI 펫로스 미술치료 프로그램",
    link: {
      label: "팀 소개 페이지",
      href: "http://www.u300.kr/cms/process/team/view.asp?c_show_no=144&c_check_no=97&c_relation=996&c_relation2=1014&c_no=25401&s_field=team_name&s_text=%EC%96%B8%ED%8E%98%EC%9D%BC&page=1",
    },
  },
  {
    period: "2023.11.28",
    title: "X-corps+ 페스티벌 과기부장관상",
    detail:
      "Block Chain 기반 Battery Management System Data 관리 및 배포를 통한 IoT 연계 확장 Business Model 연구",
    link: {
      label: "교내 기사 링크",
      href: "http://isrc.cau.ac.kr/2023-%EB%8C%80%ED%95%9C%EB%AF%BC%EA%B5%AD-%EB%AF%B8%EB%9E%98%EC%9D%B8%EC%9E%AC-%ED%8E%98%EC%8A%A4%ED%8B%B0%EB%B2%8C-2023-x-corps-plus-festival/",
    },
  },
  {
    period: "2023.03 - 2023.11",
    title: "학생창업유망 300+ 예비트랙 인기상",
    detail: "반려동물 AI 온라인 스튜디오 SPETTRUM",
  },
  {
    period: "2022.10 - 2023.02",
    title: "멀티캠퍼스 백엔드 개발자 취업캠프 수료",
    detail: "KDT 훈련과정 - Java Spring 백엔드 과정 수강",
  },
  {
    period: "2021.08.13",
    title: "중앙대-두산인프라코어 캡스톤 디자인 대회 우수상",
    detail: "중앙대학교 100주년 기념관 지도 키오스크",
  },
];

const languages = [
  { name: "Korean", level: "Native speaker" },
  { name: "English", level: "Native speaker" },
  { name: "Chinese", level: "Proficient speaker" },
] as const;

const certificates = [
  { name: "OPIc AL", date: "2026.07.16 취득" },
  { name: "HSK 6급", date: "2015.01.10 취득" },
] as const;
---

<Layout
  title="Résumé"
  description="Résumé of Sangmin (Poby) Kim — platform engineering, backend development, and data engineering."
>
  <header class="page-header">
    <p class="eyebrow">Résumé</p>
    <h1>Sangmin Kim</h1>
    <p>
      내가 만든 프로그램/서비스가 사람들에게 널리 사용되길 바라는 개발자 김상민입니다. 레거시 업무
      시스템을 웹 기반 플랫폼으로 전환하고, Linux/NixOS 기반 인프라를 선언적으로 운영하며, 자동화와
      모니터링 중심의 Platform Engineering 역량을 쌓아온 엔지니어입니다.
    </p>
    <p class="resume-motto">“확실한 근거를 바탕으로 후회없는 결정을 내리자”</p>
    <ul class="resume-contacts">
      {
        contacts.map(({ label, href, icon: Icon }) => (
          <li>
            <a href={href} aria-label={label} title={label}>
              <Icon size={20} aria-hidden="true" />
            </a>
          </li>
        ))
      }
    </ul>
  </header>

  <section class="page-section" aria-labelledby="resume-skills-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-skills-title">Skills</h2>
      </div>
    </div>
    <div class="card-grid card-grid--two">
      {
        skills.map((group) => (
          <article class="section-card">
            <h3>{group.category}</h3>
            <ul class="tag-list" aria-label={`${group.category} skills`}>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="resume-experience-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-experience-title">Experience</h2>
      </div>
    </div>
    <ol class="resume-entries">
      {
        experiences.map((experience) => (
          <li class="resume-entry">
            <span class="resume-entry__period">{experience.period}</span>
            <div class="resume-entry__body">
              <h3>
                {experience.role} <span class="resume-entry__org">@ {experience.org}</span>
              </h3>
              <ul>
                {experience.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="page-section" aria-labelledby="resume-projects-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-projects-title">Projects</h2>
      </div>
    </div>
    <div class="resume-projects">
      {
        projects.map((project) => (
          <article class="resume-project">
            <div class="resume-project__head">
              <h3>
                {project.name}
                {project.github && (
                  <a
                    href={project.github}
                    aria-label={`${project.name} GitHub repository`}
                    title="GitHub"
                  >
                    <Github size={18} aria-hidden="true" />
                  </a>
                )}
              </h3>
              <span class="resume-entry__period">{project.period}</span>
            </div>
            <p class="resume-project__stack">{project.stack.join(" · ")}</p>
            <p class="resume-project__tagline">{project.tagline}</p>
            <ul>
              {project.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="resume-education-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-education-title">Education</h2>
      </div>
    </div>
    <ol class="resume-entries">
      <li class="resume-entry">
        <span class="resume-entry__period">2017.03 - 2025.02</span>
        <div class="resume-entry__body">
          <h3>중앙대학교</h3>
          <ul>
            <li>전자전기공학 학사 졸업</li>
          </ul>
        </div>
      </li>
    </ol>
  </section>

  <section class="page-section" aria-labelledby="resume-activities-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-activities-title">Academic Activities</h2>
      </div>
    </div>
    <ol class="resume-entries">
      {
        activities.map((activity) => (
          <li class="resume-entry">
            <span class="resume-entry__period">{activity.period}</span>
            <div class="resume-entry__body">
              <h3>{activity.title}</h3>
              <ul>
                <li>
                  {activity.detail}
                  {activity.link && (
                    <>
                      {" - "}
                      <a href={activity.link.href}>{activity.link.label}</a>
                    </>
                  )}
                </li>
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="page-section" aria-labelledby="resume-language-title">
    <div class="section-heading">
      <div>
        <h2 id="resume-language-title">Languages &amp; Certificates</h2>
      </div>
    </div>
    <div class="card-grid card-grid--two">
      <article class="section-card">
        <h3>Languages</h3>
        <ul class="resume-facts">
          {
            languages.map((language) => (
              <li>
                <strong>{language.name}</strong> — {language.level}
              </li>
            ))
          }
        </ul>
      </article>
      <article class="section-card">
        <h3>Certificates</h3>
        <ul class="resume-facts">
          {
            certificates.map((certificate) => (
              <li>
                <strong>{certificate.name}</strong> <small>{certificate.date}</small>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>
</Layout>

<style>
  .resume-motto {
    font-family: var(--font-mono);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .resume-contacts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.35rem 0 0;
    padding: 0;
    list-style: none;
  }

  .resume-contacts a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--muted);
  }

  .resume-contacts a:hover {
    border-color: var(--line-strong);
    color: var(--accent-strong);
  }

  .resume-entries {
    display: grid;
    gap: 1.6rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-entry {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1rem;
  }

  .resume-entry__period {
    padding-top: 0.2rem;
    color: var(--soft);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 680;
  }

  .resume-entry__body h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .resume-entry__org {
    color: var(--muted);
    font-weight: 600;
  }

  .resume-entry__body ul,
  .resume-project ul {
    display: grid;
    gap: 0.3rem;
    margin: 0.55rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .resume-projects {
    display: grid;
    gap: 1rem;
  }

  .resume-project {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 1.3rem 1.4rem;
  }

  .resume-project__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
  }

  .resume-project__head h3 {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 1.2rem;
  }

  .resume-project__head h3 a {
    display: inline-flex;
    color: var(--muted);
  }

  .resume-project__head h3 a:hover {
    color: var(--accent-strong);
  }

  .resume-project__stack {
    margin: 0.45rem 0 0;
    color: var(--soft);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 680;
  }

  .resume-project__tagline {
    margin: 0.8rem 0 0;
    font-weight: 640;
  }

  .resume-facts {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--muted);
  }

  .resume-facts strong {
    color: var(--ink);
    font-weight: 680;
  }

  .resume-facts small {
    color: var(--soft);
    font-family: var(--font-mono);
  }

  @media (max-width: 720px) {
    .resume-entry {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
