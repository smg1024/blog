---
import { Github, Linkedin, Mail } from "lucide-astro";

import Layout from "../layouts/Layout.astro";

const contacts = [
  { label: "Email", href: "mailto:smg981024@gmail.com", icon: Mail },
  { label: "GitHub", href: "https://github.com/smg1024", icon: Github },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/sangmin-poby/", icon: Linkedin },
