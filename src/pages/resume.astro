interface Project {
  name: string;
  period: string;
  stack: string[];
  tagline: string;
  points: string[];
  github?: string;
}

const projects: Project[] = [
  {
    name: "Homelab",
    period: "2026.05 ~",
    stack: ["Nix", "NixOS", "Bash", "Caddy", "Tailscale", "Beszel", "VictoriaLogs", "Uptime Kuma"],
    tagline: "NixOS 기반 개인 인프라 플랫폼 구축/운영",
    github: "https://github.com/smg1024/homelab",
    points: [
      "Nix Flake를 단일 source of truth로 사용해 3개 호스트의 OS 설정, 서비스, 사용자 환경, 암호화 secrets를 선언적으로 관리",
      "GitHub Actions, Tailscale, SSH를 활용해 merge 이후 각 노드에 nixos-rebuild switch를 수행하는 CD 파이프라인 구성",
      "Cloudflare Tunnel, Caddy, Tailscale 기반 ingress 구조를 설계하고 public traffic과 internal backend traffic을 분리",
      "Beszel, VictoriaLogs, Uptime Kuma 기반 모니터링 및 상태 확인 체계 운영",
    ],
