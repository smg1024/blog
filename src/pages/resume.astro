---
import ResumeContent from "../components/ResumeContent.astro";
import { resumeEn } from "../data/resume.en";
import { resumeKo } from "../data/resume.ko";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Résumé"
  description="Résumé of Sangmin (Poby) Kim — platform engineering, backend development, and data engineering."
>
  <div class="resume-language-root" data-resume-root>
    <div id="resume-content" data-resume-content-host></div>

    <template data-resume-template="ko">
      <ResumeContent resume={resumeKo} />
    </template>
    <template data-resume-template="en">
      <ResumeContent resume={resumeEn} />
    </template>

    <noscript>
      <ResumeContent resume={resumeEn} showLanguageSwitcher={false} />
    </noscript>

    <script is:inline>
      (() => {
        const root = document.currentScript?.closest("[data-resume-root]");
        const host = root?.querySelector("[data-resume-content-host]");
        const storageKey = "resume-language";

        if (!(root instanceof HTMLElement) || !(host instanceof HTMLElement)) return;

        const isLocale = (value) => value === "ko" || value === "en";

        const getInitialLocale = () => {
          try {
            const storedLocale = localStorage.getItem(storageKey);
            if (isLocale(storedLocale)) return storedLocale;
          } catch {
            // Storage can be unavailable in privacy-restricted browser contexts.
          }

          const browserLanguage = navigator.languages?.[0] || navigator.language || "en";
          return browserLanguage.toLowerCase().startsWith("ko") ? "ko" : "en";
        };

        const render = (locale) => {
          if (!isLocale(locale)) return;

          const template = root.querySelector(`[data-resume-template="${locale}"]`);
          if (!(template instanceof HTMLTemplateElement)) return;

          host.replaceChildren(template.content.cloneNode(true));
          host.lang = locale;
          root.dataset.resumeLocale = locale;

          host.querySelectorAll("[data-resume-locale-button]").forEach((button) => {
            const selected = button.getAttribute("data-resume-locale-button") === locale;
            button.setAttribute("aria-pressed", String(selected));
          });
        };

        root.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;

          const button = event.target.closest("[data-resume-locale-button]");
          if (!(button instanceof HTMLButtonElement)) return;

          const locale = button.getAttribute("data-resume-locale-button");
          if (!isLocale(locale)) return;

          render(locale);

          try {
            localStorage.setItem(storageKey, locale);
          } catch {
            // The active page can still switch languages without persistence.
          }
        });

        render(getInitialLocale());
      })();
    </script>
  </div>
</Layout>
