---
import Layout from "../layouts/Layout.astro";
---

<Layout title="CV" description="Formal career, skills, and experience page for Min.">
  <header class="page-header">
    <p class="eyebrow">Professional record</p>
    <h1>CV</h1>
    <p>A formal page for career history, skills, projects, education, certifications, and professional links.</p>
  </header>

  <section class="page-section" aria-labelledby="cv-foundation-title">
    <div class="section-heading">
      <div>
        <h2 id="cv-foundation-title">Foundation</h2>
        <p>
          The page is intentionally structured now, with real content to be filled in as your public resume evolves.
        </p>
      </div>
    </div>
    <div class="card-grid card-grid--two">
      <article class="section-card">
        <h3>Experience</h3>
        <p>Roles, responsibilities, systems operated, and meaningful technical outcomes.</p>
      </article>
      <article class="section-card">
        <h3>Skills</h3>
        <p>Languages, infrastructure, DevOps practices, tools, and areas of depth.</p>
      </article>
      <article class="section-card">
        <h3>Projects</h3>
        <p>Selected public work and private projects that can be described as case studies.</p>
      </article>
      <article class="section-card">
        <h3>Links</h3>
        <p>GitHub, email, professional profiles, and downloadable resume when ready.</p>
      </article>
    </div>
  </section>
</Layout>
