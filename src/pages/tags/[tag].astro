---
import PostCard from "../../components/PostCard.astro";
import Layout from "../../layouts/Layout.astro";
import {
  getPublishedBlog,
  getTagSummaries,
  getBlogByTagSlug,
  type TagSummary,
  type BlogEntry,
} from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedBlog();
  const tags = getTagSummaries(posts);

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tag,
      posts: getBlogByTagSlug(posts, tag.slug),
    },
  }));
}

interface Props {
  tag: TagSummary;
  posts: BlogEntry[];
}

const { tag, posts } = Astro.props;
---

<Layout title={`#${tag.name}`} description={`Tag: ${tag.name}. Blog posts, related notes.`}>
  <header class="page-header">
    <p class="eyebrow">Tag</p>
    <h1>#{tag.name}</h1>
    <p>{posts.length} {posts.length === 1 ? "post" : "posts"} / {tag.name}</p>
  </header>

  <section class="page-section" aria-labelledby="tag-posts-title">
    <div class="section-heading">
      <div>
        <h2 id="tag-posts-title">Tagged posts</h2>
      </div>
      <a href="/tags">All tags</a>
    </div>
    {
      posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="empty-state">No posts yet.</p>
      )
    }
  </section>
</Layout>
