---
import PostCard from "../components/PostCard.astro";
import { blogSections, blogUtilities } from "../data/site";
import Layout from "../layouts/Layout.astro";
import { getDraftBlog, getPublishedBlog } from "../lib/content";

const posts = await getPublishedBlog();
const draftPosts = await getDraftBlog();
---

<Layout title="Blog" description="Light notes, field logs, deep dives, practical systems learning.">
  <header class="page-header">
    <p class="eyebrow">Blog</p>
    <h1>Notes, logs, and deep dives.</h1>
    <p>Focus levels, quick notes, field logs, deeper essays.</p>
  </header>

  <section class="page-section" aria-labelledby="tracks-title">
    <div class="section-heading">
      <div>
        <h2 id="tracks-title">Tracks</h2>
        <p>Focus level, operational depth, reading weight.</p>
      </div>
    </div>
    <div class="card-grid">
      {
        blogSections.map((section) => (
          <a class="section-card" href={section.href}>
            <div class="card-meta">{section.intensity}</div>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="indexes-title">
    <div class="section-heading">
      <div>
        <h2 id="indexes-title">Indexes</h2>
      </div>
    </div>
    <div class="card-grid card-grid--two">
      {
        blogUtilities.map((section) => (
          <a class="section-card" href={section.href}>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="all-blog-title">
    <div class="section-heading">
      <div>
        <h2 id="all-blog-title">Published posts</h2>
      </div>
    </div>
    {
      posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="empty-state">No blog posts yet.</p>
      )
    }
  </section>

  {
    draftPosts.length > 0 && (
      <section class="page-section draft-section" aria-labelledby="draft-blog-title">
        <div class="section-heading">
          <div>
            <h2 id="draft-blog-title">Drafts</h2>
            <p>Local previews, unpublished notes.</p>
          </div>
        </div>
        <div class="post-list">
          {draftPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }
</Layout>
