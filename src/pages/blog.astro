---
import PostCard from "../components/PostCard.astro";
import { blogSections, blogUtilities } from "../data/site";
import Layout from "../layouts/Layout.astro";
import { getDraftBlog, getPublishedBlog } from "../lib/content";

const posts = await getPublishedBlog();
const draftPosts = await getDraftBlog();
---

<Layout
  title="Blog"
  description="Blog posts from Dev with Min, organized by intensity: light notes, field logs, and deep dives."
>
  <header class="page-header">
    <p class="eyebrow">Blog</p>
    <h1>Notes, logs, and deep dives.</h1>
    <p>
      The blog archive is split by intensity so a quick tool note does not compete with a long
      DevOps or computer science essay.
    </p>
  </header>

  <section class="page-section" aria-labelledby="tracks-title">
    <div class="section-heading">
      <div>
        <h2 id="tracks-title">Tracks</h2>
        <p>Start from the amount of focus a post asks from you.</p>
      </div>
    </div>
    <div class="card-grid">
      {
        blogSections.map((section) => (
          <a class="section-card" href={section.href}>
            <div class="card-meta">{section.intensity}</div>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
            <ul class="example-list" aria-label={`${section.title} examples`}>
              {section.examples.map((example) => (
                <li>{example}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="indexes-title">
    <div class="section-heading">
      <div>
        <h2 id="indexes-title">Indexes</h2>
      </div>
    </div>
    <div class="card-grid card-grid--two">
      {
        blogUtilities.map((section) => (
          <a class="section-card" href={section.href}>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="page-section" aria-labelledby="all-blog-title">
    <div class="section-heading">
      <div>
        <h2 id="all-blog-title">Published posts</h2>
      </div>
    </div>
    {
      posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="empty-state">No blog posts have been published yet.</p>
      )
    }
  </section>

  {
    draftPosts.length > 0 && (
      <section class="page-section draft-section" aria-labelledby="draft-blog-title">
        <div class="section-heading">
          <div>
            <h2 id="draft-blog-title">Drafts</h2>
            <p>Visible only during local development.</p>
          </div>
        </div>
        <div class="post-list">
          {draftPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }
</Layout>
