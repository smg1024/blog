---
import Layout from "../layouts/Layout.astro";
import { blogUtilities } from "../data/site";
import { formatDate, getPublishedBlog, getDraftBlog, getBlogUrl } from "../lib/content";

const posts = await getPublishedBlog();
const draftPosts = await getDraftBlog();
---

<Layout
  title="Blog"
  description="Notes, logs, and essays on homelab infrastructure, DevOps, AI agents, and systems thinking."
>
  <header class="page-header">
    <h1>Blog</h1>
    <p>Notes, logs, and essays — newest first. Browse by topic on the tags page.</p>
    <nav class="index-links" aria-label="Blog indexes">
      {blogUtilities.map((item) => <a href={item.href}>{item.title}</a>)}
      <a href="/rss.xml">RSS</a>
    </nav>
  </header>

  <section class="page-section" aria-labelledby="all-blog-title">
    <h2 id="all-blog-title" class="sr-only">All posts</h2>
    {
      posts.length > 0 ? (
        <ol class="post-log">
          {posts.map((post) => (
            <li>
              <a href={getBlogUrl(post)}>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
                <span class="post-log__body">
                  <strong>{post.data.title}</strong>
                  <small>{post.data.description}</small>
                </span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty-state">No blog posts yet.</p>
      )
    }
  </section>

  {
    draftPosts.length > 0 && (
      <section class="page-section draft-section" aria-labelledby="draft-blog-title">
        <div class="section-heading">
          <div>
            <h2 id="draft-blog-title">Drafts</h2>
            <p>Local previews, unpublished notes.</p>
          </div>
        </div>
        <ol class="post-log">
          {draftPosts.map((post) => (
            <li>
              <a href={getBlogUrl(post)}>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
                <span class="post-log__body">
                  <strong>{post.data.title}</strong>
                  <small>{post.data.description}</small>
                </span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }
</Layout>
