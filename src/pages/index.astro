---
import { currentFocus, projectSeeds, SITE, writingSections } from "../data/site";
import Layout from "../layouts/Layout.astro";
import { formatDate, getPublishedWriting, getSectionLabel, getWritingUrl } from "../lib/content";

const allWriting = await getPublishedWriting();
const latestWriting = allWriting.slice(0, 6);
const writingGroups = writingSections.map((section) => ({
  ...section,
  posts: allWriting.filter((post) => post.data.section === section.key).slice(0, 3),
}));
const profileLinks = [
  {
    title: "Profile",
    href: "/profile",
    description: "Who I am as a developer.",
  },
  {
    title: "CV",
    href: "/cv",
    description: "Career, skills, and professional context.",
  },
  {
    title: "Timeline",
    href: "/timeline",
    description: "My developer history as it unfolds.",
  },
  {
    title: "Uses",
    href: "/uses",
    description: "Hardware, software, and homelab setup.",
  },
];
---

<Layout title={SITE.name} description={SITE.description}>
  <section class="personal-hero" aria-labelledby="home-title">
    <div class="personal-hero__copy">
      <p class="eyebrow">Dev with Min</p>
      <h1 id="home-title">Hey, I'm Min.</h1>
      <p class="lede">
        I write about building software, running a homelab, learning DevOps, using AI agents, and the tools I live with
        every day.
      </p>
      <p>
        This is my personal developer journal: part blog, part project record, part setup log, and part history of the
        things I learn through honest engineering work.
      </p>
      <nav class="personal-links" aria-label="Personal links">
        <a href="/profile">About</a>
        <a href="/projects">Projects</a>
        <a href="/timeline">Timeline</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </div>

    <aside class="personal-hero__aside" aria-label="Current focus">
      <img
        class="personal-photo"
        src="/images/dev-with-min-journal.png"
        alt="A developer workspace with a laptop, notebook, keyboard, and homelab equipment."
        fetchpriority="high"
      >
      <div class="now-panel">
        <p class="eyebrow">Now</p>
        <ul class="status-list">
          {currentFocus.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </aside>
  </section>

  <section class="home-section" aria-labelledby="latest-title">
    <div class="home-section__header">
      <div>
        <p class="eyebrow">Latest writing</p>
        <h2 id="latest-title">Recently published</h2>
      </div>
      <a href="/archive">Full archive</a>
    </div>

    {latestWriting.length > 0 ? (
        <ol class="simple-post-list">
          {latestWriting.map((post) => (
            <li>
              <a href={getWritingUrl(post)}>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
                <span>
                  <strong>{post.data.title}</strong>
                  <small>{post.data.description}</small>
                </span>
                <em>{getSectionLabel(post.data.section)}</em>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty-state">No writing has been published yet.</p>
      )}
  </section>

  <section class="home-section" aria-labelledby="writing-title">
    <div class="home-section__header">
      <div>
        <p class="eyebrow">Writing</p>
        <h2 id="writing-title">Notes, logs, and deep dives</h2>
        <p>
          I keep casual notes separate from experience logs and heavier essays, so the archive stays easy to browse as
          it grows.
        </p>
      </div>
      <a href="/writing">Writing index</a>
    </div>

    <div class="writing-lanes">
      {writingGroups.map((section) => (
          <section
            class="writing-lane"
            aria-labelledby={`${section.key}-title`}
          >
            <header>
              <div>
                <p>{section.intensity}</p>
                <h3 id={`${section.key}-title`}>
                  <a href={section.href}>{section.title}</a>
                </h3>
              </div>
            </header>
            <p>{section.description}</p>
            {section.posts.length > 0 ? (
              <ul class="mini-post-list">
                {section.posts.map((post) => (
                  <li>
                    <a href={getWritingUrl(post)}>{post.data.title}</a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="quiet-note">No posts yet.</p>
            )}
          </section>
        ))}
    </div>
  </section>

  <section class="home-section" aria-labelledby="projects-title">
    <div class="home-section__header">
      <div>
        <p class="eyebrow">Work and identity</p>
        <h2 id="projects-title">Projects, profile, and history</h2>
        <p>These pages keep the professional and personal context close to the writing.</p>
      </div>
    </div>

    <div class="profile-project-grid">
      <div class="profile-link-list">
        {profileLinks.map((link) => (
            <a href={link.href}>
              <strong>{link.title}</strong>
              <span>{link.description}</span>
            </a>
          ))}
      </div>

      <div class="home-project-list">
        {projectSeeds.map((project) => (
            <article class="home-project">
              <div>
                <span>{project.status}</span>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </div>
              <ul class="tag-list" aria-label={`${project.title} tags`}>
                {project.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </article>
          ))}
      </div>
    </div>
  </section>
</Layout>
