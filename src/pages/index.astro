---
import {
  currentFocus,
  identitySections,
  projectSeeds,
  sectionVisibility,
  SITE,
  blogSections,
} from "../data/site";
import Layout from "../layouts/Layout.astro";
import { formatDate, getPublishedBlog, getSectionLabel, getBlogUrl } from "../lib/content";

const allBlog = await getPublishedBlog();
const latestBlog = allBlog.slice(0, 6);
const blogGroups = blogSections.map((section) => ({
  ...section,
  posts: allBlog.filter((post) => post.data.section === section.key).slice(0, 3),
}));
const profileLinks = identitySections.filter((section) => section.visible);
const showProjectsPreview = sectionVisibility.projects;
const showIdentitySections = profileLinks.length > 0 || showProjectsPreview;
---

<Layout title={SITE.name} description={SITE.description}>
  <section class="personal-hero" aria-labelledby="home-title">
    <div class="personal-hero__copy">
      <p class="eyebrow">Dev with Min</p>
      <h1 id="home-title">Hey, I'm Poby.</h1>
      <p class="lede">
        I write about building software, running a homelab, learning DevOps, using AI agents, and
        the tools I live with every day.
      </p>
      <p>
        This is my personal developer journal for notes, field logs, and longer essays about the
        things I learn through honest engineering work.
      </p>
      <nav class="personal-links" aria-label="Personal links">
        <a href="/blog">Blog</a>
        <a href="/archive">Archive</a>
        <a href="/tags">Tags</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </div>

    <aside class="personal-hero__aside" aria-label="Current focus">
      <img
        class="personal-photo"
        src="/images/logo.png"
        alt="Dev with Min logo showing a bear face framed by code brackets."
        fetchpriority="high"
      />
      <div class="now-panel">
        <p class="eyebrow">Now</p>
        <ul class="status-list">
          {currentFocus.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </aside>
  </section>

  <section class="home-section" aria-labelledby="latest-title">
    <div class="home-section__header">
      <div>
        <p class="eyebrow">Latest blog posts</p>
        <h2 id="latest-title">Recently published</h2>
      </div>
      <a href="/archive">Full archive</a>
    </div>

    {
      latestBlog.length > 0 ? (
        <ol class="simple-post-list">
          {latestBlog.map((post) => (
            <li>
              <a href={getBlogUrl(post)}>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
                <span>
                  <strong>{post.data.title}</strong>
                  <small>{post.data.description}</small>
                </span>
                <em>{getSectionLabel(post.data.section)}</em>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty-state">No blog posts have been published yet.</p>
      )
    }
  </section>

  <section class="home-section" aria-labelledby="blog-title">
    <div class="home-section__header">
      <div>
        <p class="eyebrow">Blog</p>
        <h2 id="blog-title">Notes, logs, and deep dives</h2>
        <p>
          I keep casual notes separate from experience logs and heavier essays, so the blog stays
          easy to browse as it grows.
        </p>
      </div>
      <a href="/blog">Blog index</a>
    </div>

    <div class="blog-lanes">
      {
        blogGroups.map((section) => (
          <section class="blog-lane" aria-labelledby={`${section.key}-title`}>
            <header>
              <div>
                <p>{section.intensity}</p>
                <h3 id={`${section.key}-title`}>
                  <a href={section.href}>{section.title}</a>
                </h3>
              </div>
            </header>
            <p>{section.description}</p>
            {section.posts.length > 0 ? (
              <ul class="mini-post-list">
                {section.posts.map((post) => (
                  <li>
                    <a href={getBlogUrl(post)}>{post.data.title}</a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="quiet-note">No posts yet.</p>
            )}
          </section>
        ))
      }
    </div>
  </section>

  {
    showIdentitySections && (
      <section class="home-section" aria-labelledby="projects-title">
        <div class="home-section__header">
          <div>
            <p class="eyebrow">Work and identity</p>
            <h2 id="projects-title">Projects, profile, and history</h2>
            <p>These pages keep the professional and personal context close to the blog.</p>
          </div>
        </div>

        <div class="profile-project-grid">
          {profileLinks.length > 0 && (
            <div class="profile-link-list">
              {profileLinks.map((link) => (
                <a href={link.href}>
                  <strong>{link.title}</strong>
                  <span>{link.description}</span>
                </a>
              ))}
            </div>
          )}

          {showProjectsPreview && (
            <div class="home-project-list">
              {projectSeeds.map((project) => (
                <article class="home-project">
                  <div>
                    <span>{project.status}</span>
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                  </div>
                  <ul class="tag-list" aria-label={`${project.title} tags`}>
                    {project.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    )
  }
</Layout>
