---
import Layout from "../layouts/Layout.astro";
import { getPublishedTags, getTagUrl } from "../lib/content";

const tags = await getPublishedTags();
---

<Layout
  title="Tags"
  description="Browse Dev with Min writing by recurring tools, topics, and ideas."
>
  <header class="page-header">
    <p class="eyebrow">Writing index</p>
    <h1>Tags</h1>
    <p>Recurring tools, topics, and ideas across the writing archive.</p>
  </header>

  <section class="page-section" aria-labelledby="tags-list-title">
    <div class="section-heading">
      <div>
        <h2 id="tags-list-title">All tags</h2>
      </div>
    </div>
    {
      tags.length > 0 ? (
        <div class="tag-cloud">
          {tags.map((tag) => (
            <a class="tag-card" href={getTagUrl(tag.name)}>
              <strong>{tag.name}</strong>
              <span>
                {tag.count} {tag.count === 1 ? "post" : "posts"}
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">Tags will appear here once posts include them.</p>
      )
    }
  </section>
</Layout>
